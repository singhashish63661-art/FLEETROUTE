# ─── Database ────────────────────────────────────────────────────────────────
TIMESCALE_DSN=postgres://gpsgo:gpsgo@timescaledb:5432/gpsgo?sslmode=disable
REDIS_ADDR=redis:6379
REDIS_PASSWORD=

# ─── NATS ────────────────────────────────────────────────────────────────────
NATS_URL=nats://nats:4222

# ─── Auth (generate with: openssl genrsa -out private.pem 2048) ──────────────
JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_public.pem
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# ─── Ingestion Ports ─────────────────────────────────────────────────────────
PORT_GT06=5001
PORT_TK103=5002
PORT_JT808=5003
PORT_AIS140=5004
PORT_TELTONIKA_TCP=5027
PORT_TELTONIKA_UDP=5028

# ─── API Service ─────────────────────────────────────────────────────────────
API_PORT=8080
API_BASE_URL=http://api-service:8080

# ─── WebSocket Service ───────────────────────────────────────────────────────
WS_PORT=8081

# ─── Notification Providers ──────────────────────────────────────────────────
NOTIFICATION_EMAIL_PROVIDER=stub    # stub | sendgrid | ses
NOTIFICATION_SMS_PROVIDER=stub      # stub | twilio | sns
SENDGRID_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ─── AIS140 / VLTD ──────────────────────────────────────────────────────────
AIS140_ITS_ENDPOINT=https://its.example.gov.in/api/emergency
AIS140_ITS_API_KEY=

# ─── Observability ───────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
LOG_LEVEL=info
